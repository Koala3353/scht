GOOGLE_CLOUD_PROJECT_ID=scht-502902
# Server-only shared token for the Apps Script reminder callback.
REMINDER_DISPATCH_TOKEN=
HACK_CLUB_AI_BASE_URL=https://ai.hackclub.com/v1
